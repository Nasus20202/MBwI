@article{ning_literature_2025,
	title = {A literature review on {AI} and the global green value chains},
	volume = {3},
	issn = {2731-9423},
	url = {https://link.springer.com/10.1007/s44265-025-00071-8},
	doi = {10.1007/s44265-025-00071-8},
	abstract = {Abstract
            Against the backdrop of increasingly severe global climate change and environmental challenges, the traditional energy-intensive and high-emission global value chain model urgently requires transformation towards greener alternatives. The global green value chain (GGVC), by integrating environmentally friendly technologies and practices to optimize resource allocation and reduce carbon emissions, has emerged as a critical pathway for achieving synergistic development between economic growth and environmental protection. Artificial intelligence (AI) technology, leveraging its strengths in data analytics and intelligent decision-making, provides innovative solutions for constructing such green value chains. This study systematically reviews the research progress on the application of AI technology in the GGVC. Through the analysis of core documents, the crucial role of AI in promoting the green transformation of the global value chain has been revealed. The existing literature has found that AI technology is reshaping the development paradigm of the global green economy by empowering innovation throughout the entire industrial chain. In the upstream segments, AI accelerates the research and development of green materials and process optimization. The midstream segments realizes intelligent manufacturing and low-carbon logistics. The downstream links promote green consumption and recycling. This paper constructs a theoretical framework for the development of the global green value chain driven by AI from three dimensions: Technology application, economic impact, and governance challenges, and proposes future research directions.},
	language = {en},
	number = {1},
	urldate = {2026-03-14},
	journal = {Digit. Econ. Sustain. Dev.},
	author = {Ning, Jing and Yang, Zheng},
	month = oct,
	year = {2025},
	pages = {24},
	file = {Full Text:files/401/Ning and Yang - 2025 - A literature review on AI and the global green value chains.pdf:application/pdf},
}

@article{garn_transparency_2025,
	title = {Transparency of combinatorial optimisations via machine learning and explainable {AI}},
	volume = {354},
	issn = {0254-5330, 1572-9338},
	url = {https://link.springer.com/10.1007/s10479-025-06684-8},
	doi = {10.1007/s10479-025-06684-8},
	abstract = {Abstract
            In this golden age of artificial intelligence, transparency and responsible decision-making are paramount. While machine learning (ML) and operational research (OR) optimisations are fundamental aspects of AI, the benefits of explainable AI (XAI) for combinatorial optimisations remain underexplored. This study investigates the convergence of XAI and OR, emphasising the importance of transparency in combinatorial optimisations. Using the Knapsack problem as an example, we demonstrate that interpretable ML models can effectively solve combinatorial optimisation challenges and enhance transparency. Additionally, we illustrate the application of post-hoc XAI methods to OR optimisations solved with ML, providing transparent, human-friendly explanations. The key contributions of this work include proposing the application of the SAGE framework for transparent OR, demonstrating the integration of XAI with combinatorial optimisations, and offering practical guidelines for creating transparent explanations. These contributions can aid decision-makers in understanding, communicating, and trusting combinatorial optimisation solutions, paving the way for enhanced transparency in operational research across various sectors.},
	language = {en},
	number = {1},
	urldate = {2026-03-14},
	journal = {Ann Oper Res},
	author = {Garn, Wolfgang and Amirghasemi, Mehrdad},
	month = nov,
	year = {2025},
	pages = {427--458},
	file = {Full Text:files/403/Garn and Amirghasemi - 2025 - Transparency of combinatorial optimisations via machine learning and explainable AI.pdf:application/pdf},
}

