@article{salgotra_rise_2026,
	title = {The {Rise} of {Particle} {Swarm} {Optimization}: {A} {Systematic} {Bibliometric} \& {Thematic} {Review} (1995–2025)},
	issn = {1134-3060, 1886-1784},
	shorttitle = {The {Rise} of {Particle} {Swarm} {Optimization}},
	url = {https://link.springer.com/10.1007/s11831-026-10532-8},
	doi = {10.1007/s11831-026-10532-8},
	abstract = {Abstract
            Since its inception in 1995, Particle Swarm Optimization (PSO) has become a cornerstone in the field of computational intelligence and metaheuristic optimization. This paper presents a comprehensive bibliometric and thematic review of PSO research conducted over the last 30 years (1995–2025). By analyzing 26,089 publications sourced from the Scopus, Web of Science (WOS) and IEEE Xplore databases, we offer a multifaceted view of the evolution, contributions, and applications of the algorithm. Through the use of advanced visualization techniques, such as Sankey diagrams (illustrating institution-country-keyword flows), Choropleth maps (depicting global publication geographies), coauthorship and citation networks, and heatmaps (showing cross-domain research impact), the paper identifies leading contributors, thematic clusters, and emerging trends. The analysis covers publication trends, core contributors, research themes, and domain-specific applications, with a particular focus on 13 core application areas that include engineering, artificial intelligence, energy systems, and more. The review highlights the evolution of PSO variants, the emergence of hybrid models, growing multidisciplinary applications, and the rise of Asia (especially China and India) as a hub of PSO research. Finally, through coauthorship mapping, keyword cooccurrence, and thematic clustering, this article identifies the leading trends, research silos, and emerging challenges, providing a roadmap for future PSO research.},
	language = {en},
	urldate = {2026-03-14},
	journal = {Arch Computat Methods Eng},
	author = {Salgotra, Rohit and Chaudhary, Reshu and Verma, Pooja and Mirjalili, Sayedali},
	month = mar,
	year = {2026},
	file = {Full Text PDF:files/429/Salgotra et al. - 2026 - The Rise of Particle Swarm Optimization A Systematic Bibliometric & Thematic Review (1995–2025).pdf:application/pdf},
}

