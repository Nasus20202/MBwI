}

@incollection{saqr_ai_2026,
	address = {Cham},
	title = {{AI}, {Explainable} {AI} and {Evaluative} {AI}: {Informed} {Data}-{Driven} {Decision}-{Making} in {Education}},
	isbn = {978-3-031-95364-4 978-3-031-95365-1},
